<?xml version="1.0" encoding="utf-8"?>
<!-- Rename to Requirements.props and specify local paths -->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets" />
  <PropertyGroup Label="UserMacros">
    <CLI11></CLI11><!-- https://github.com/CLIUtils/CLI11 -->
    <Catch2></Catch2><!-- https://github.com/catchorg/Catch2/tree/v2.x -->
  </PropertyGroup>
  <PropertyGroup />
  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>$(CLI11)\include;$(Catch2)\single_include\catch2;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemGroup>
    <BuildMacro Include="CLI11">
      <Value>$(CLI11)</Value>
    </BuildMacro>
    <BuildMacro Include="Catch2">
      <Value>$(Catch2)</Value>
    </BuildMacro>
  </ItemGroup>
</Project>